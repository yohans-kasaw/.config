{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "grepai": {
      "type": "local",
      "enabled": true,
      "command": [
        "grepai",
        "mcp-serve"
      ]
    },
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    // "shadcn": {
    //   "enabled": true,
    //   "type": "local",
    //   "command": [
    //     "npx",
    //     "shadcn@latest",
    //     "mcp"
    //   ]
    // }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
  ],
  "provider": {
    "ollama": {
      "models": {
        "gemma4:e4b": {
          "_launch": true,
          "name": "gemma4:e4b"
        },
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  }
}
