[init]
	defaultBranch = main
[fetch]
	prune = true
[user]
	name = yohans-kasaw
	email = yohanshailukasaw@gmail.com

# delta
[core]
    pager = delta
[interactive]
    diffFilter = delta --color-only

[delta "colorscheme"]
  commit-style                  = raw
  commit-decorations-style      = blue ol
  file-style                    = omit
  hunk-header-style             = file line-number
  hunk-header-decoration-style  = blue box
  hunk-header-file-style        = red
  hunk-header-line-number-style = red
  minus-style                   = bold red
  minus-non-emph-style          = red
  minus-emph-style              = bold black red
  minus-empty-line-marker-style = normal red
  zero-style                    = normal
  plus-style                    = bold green
  plus-non-emph-style           = green
  plus-emph-style               = bold black green
  plus-empty-line-marker-style  = normal green
  whitespace-error-style        = reverse purple
  true-color                    = always
  line-numbers-zero-style       = dim normal
  line-numbers-minus-style      = red
  line-numbers-plus-style       = green
  line-numbers-left-style       = blue
  line-numbers-right-style      = blue

[delta]
    navigate = true  
    dark = true 
    ; side-by-side = true
    line-numbers = true
    syntax-theme = Dracula 
    max-line-length = 80


[merge]
    conflictstyle = zdiff3
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
